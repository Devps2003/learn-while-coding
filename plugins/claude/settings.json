{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "LEARNWHILE_PLATFORM=claude LEARNWHILE_EVENT=beforeSubmitPrompt \"$CLAUDE_PROJECT_DIR\"/scripts/hook.sh"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "matcher": "Edit|Write",
        "command": "LEARNWHILE_PLATFORM=claude LEARNWHILE_EVENT=postToolUse \"$CLAUDE_PROJECT_DIR\"/scripts/hook.sh"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "LEARNWHILE_PLATFORM=claude LEARNWHILE_EVENT=stop \"$CLAUDE_PROJECT_DIR\"/scripts/hook.sh"
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "LEARNWHILE_PLATFORM=claude LEARNWHILE_EVENT=sessionEnd \"$CLAUDE_PROJECT_DIR\"/scripts/hook.sh"
      }
    ]
  }
}
